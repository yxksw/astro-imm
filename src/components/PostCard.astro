---
import { AUTHOR_NAME, AUTHOR_AVATAR } from '../consts';

interface Props {
    title: string;
    description?: string;
    pubDate: Date;
    updatedDate?: Date;
    slug: string;
    isAdvertise?: boolean;
    position?: string;
    positionUrl?: string;
    isSingle?: boolean;
    content?: string;
    rank?: number;
    isTop?: boolean;
    showEdit?: boolean;
}

const { 
    title, 
    description, 
    pubDate, 
    updatedDate, 
    slug, 
    isAdvertise = false,
    position,
    positionUrl,
    isSingle = false,
    content = '',
    rank,
    isTop = false,
    showEdit = false
} = Astro.props;

const formattedDate = new Intl.DateTimeFormat('zh-CN', {
    year: 'numeric',
    month: 'long',
    day: 'numeric'
}).format(updatedDate || pubDate);

// 智能摘要函数
function smartExcerpt(text: string, length: number = 140): string {
    if (!text) return '';
    // 移除HTML标签
    const plainText = text.replace(/<[^>]*>/g, '');
    if (plainText.length <= length) return plainText;
    return plainText.substring(0, length) + '...';
}

const displayContent = smartExcerpt(description || content, 140);
---

<article class="post">
    <div class="author-avatar">
        <img
            alt={AUTHOR_NAME}
            loading="lazy"
            fetchpriority="low"
            src={AUTHOR_AVATAR}>
    </div>

    <div class="content">
        <div class="post-info">
            <div class="author-name">
                {AUTHOR_NAME}
                {isTop && (
                    <div class="author-badge" style="background: #ff4757;">置顶</div>
                )}
                {isAdvertise && !isTop && (
                    <div class="author-badge">广告</div>
                )}
                {isSingle && showEdit && (
                    <a href={`/admin/editor?slug=${slug}`} class="edit-badge" title="编辑文章">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" width="16" height="16">
                            <path stroke-linecap="round" stroke-linejoin="round" d="m16.862 4.487 1.687-1.688a1.875 1.875 0 1 1 2.652 2.652L10.582 16.07a4.5 4.5 0 0 1-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 0 1 1.13-1.897l8.932-8.931Zm0 0L19.5 7.125M18 14v4.75A2.25 2.25 0 0 1 15.75 21H5.25A2.25 2.25 0 0 1 3 18.75V8.25A2.25 2.25 0 0 1 5.25 6H10" />
                        </svg>
                    </a>
                )}
            </div>
            {isSingle && rank && (
                <div class="post-rank">#{rank}</div>
            )}
        </div>

        <!-- 只在列表页显示摘要，详情页不显示 -->
        {!isSingle && (
            <div class="text">
                {displayContent}
                <p class="more"><a href={`/blog/${slug}`} title={title}>…全文</a></p>
            </div>
        )}

        <div class="post-meta">
            <div class="post-position">
                {isSingle && position && (
                    <>
                        📍 
                        {positionUrl ? (
                            <a href={positionUrl} target="_blank" rel="noopener noreferrer">{position}</a>
                        ) : (
                            position
                        )}
                    </>
                )}
            </div>
            <div class="date">
                {updatedDate ? `更新于 ${formattedDate}` : formattedDate}
            </div>
        </div>
    </div>
</article>

<style>
    /* 编辑按钮样式 */
    .edit-badge {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        margin-left: 8px;
        padding: 2px 6px;
        background: var(--color-link-go, #07C160);
        border-radius: 4px;
        color: white;
        text-decoration: none;
        transition: all 0.2s ease;
        vertical-align: middle;
    }

    .edit-badge:hover {
        background: #06a950;
        transform: scale(1.05);
    }

    .edit-badge svg {
        display: block;
    }
</style>
