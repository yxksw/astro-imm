---
import { SITE_TITLE, SITE_DESCRIPTION, HEADER_CONFIG } from '../consts';

interface Props {
    isHome?: boolean;
}

const { isHome = false } = Astro.props;

// 背景图配置
const headerBgImage = HEADER_CONFIG.headerBgImage || '';
const headerBgVideo = HEADER_CONFIG.headerBgVideo || '';

// 颜色配置
const topTitleColor = HEADER_CONFIG.topTitleColor || '#ffffff';
const topDescriptionColor = HEADER_CONFIG.topDescriptionColor || '#ffffff';
const backButtonColor = HEADER_CONFIG.backButtonColor || '#ffffff';
const settingButtonColor = HEADER_CONFIG.settingButtonColor || '#ffffff';
---

{HEADER_CONFIG.showTopBar && (
    <>
        <!-- 顶部导航栏 -->
        <section class="top-container" id="top-container">
            <div class="top-container-left">
                <!-- 返回首页按钮 -->
                {!isHome && (
                    <a href="/" class="tc-back" title="返回首页" style={`color: ${backButtonColor};`}>
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" width="20" height="20">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5 3 12m0 0 7.5-7.5M3 12h18" />
                        </svg>
                    </a>
                )}
                <!-- 音乐按钮 -->
                <div class="tc-music" id="musicBtn" title="音乐播放器" style={`color: ${backButtonColor};`}>
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" width="20" height="20">
                        <path stroke-linecap="round" stroke-linejoin="round" d="m9 9 10.5-3m0 6.553v3.75a2.25 2.25 0 0 1-1.632 2.163l-1.32.377a1.803 1.803 0 1 1-.99-3.467l2.31-.66a2.25 2.25 0 0 0 1.632-2.163Zm0 0V2.25L9 5.25v10.303m0 0v3.75a2.25 2.25 0 0 1-1.632 2.163l-1.32.377a1.803 1.803 0 0 1-.99-3.467l2.31-.66A2.25 2.25 0 0 0 9 15.553Z" />
                    </svg>
                </div>
                <!-- 友链按钮 -->
                <div class="tc-links" id="linksBtn" title="友情链接" style={`color: ${backButtonColor};`}>
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" width="20" height="20">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M13.19 8.688a4.5 4.5 0 0 1 1.242 7.244l-4.5 4.5a4.5 4.5 0 0 1-6.364-6.364l1.757-1.757m13.35-.622 1.757-1.757a4.5 4.5 0 0 0-6.364-6.364l-4.5 4.5a4.5 4.5 0 0 0 1.242 7.244" />
                    </svg>
                </div>
            </div>
            <div class="top-container-right">
                <!-- 设置图标 - 点击跳转到编辑页面 -->
                <a href="/admin/editor" class="tc-setting" title="编辑文章" style={`color: ${settingButtonColor};`}>
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" width="20" height="20">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M9.594 3.94c.09-.542.56-.94 1.11-.94h2.593c.55 0 1.02.398 1.11.94l.213 1.281c.063.374.313.686.645.87.074.04.147.083.22.127.324.196.72.257 1.075.124l1.217-.456a1.125 1.125 0 0 1 1.37.49l1.296 2.247a1.125 1.125 0 0 1-.26 1.431l-1.003.827c-.293.24-.438.613-.431.992a6.759 6.759 0 0 1 0 .255c-.007.378.138.75.43.99l1.005.828c.424.35.534.954.26 1.43l-1.298 2.247a1.125 1.125 0 0 1-1.369.491l-1.217-.456c-.355-.133-.75-.072-1.076.124a6.57 6.57 0 0 1-.22.128c-.331.183-.581.495-.644.869l-.212 1.28c-.09.543-.56.941-1.11.941h-2.594c-.55 0-1.02-.398-1.11-.94l-.213-1.281c-.063-.374-.313-.686-.645-.87a6.519 6.519 0 0 1-.22-.127c-.325-.196-.72-.257-1.076-.124l-1.217.456a1.125 1.125 0 0 1-1.369-.49l-1.296-2.247a1.125 1.125 0 0 1 .26-1.431l1.004-.827c.292-.24.437-.613.43-.992a6.932 6.932 0 0 1 0-.255c.007-.378-.138-.75-.43-.99l-1.004-.828a1.125 1.125 0 0 1-.26-1.43l1.296-2.247a1.125 1.125 0 0 1 1.37-.491l1.216.456c.356.133.751.072 1.076-.124.072-.044.146-.087.22-.128.332-.183.582-.495.644-.869l.214-1.281Z" />
                        <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" />
                    </svg>
                </a>
            </div>
        </section>

        <!-- 头部横幅 -->
        <section class="header-container" style={headerBgImage ? `background-image: url(${headerBgImage});` : headerBgVideo ? '' : 'background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);'}>
            {headerBgVideo && (
                <video src={headerBgVideo} autoplay muted loop playsinline></video>
            )}

            <div class="header-info">
                <div class="header-user">
                    <a href={HEADER_CONFIG.logoLink || '/'} class="header-site-title" style={`color: ${topTitleColor};`}>
                        <span>{HEADER_CONFIG.topTitle || SITE_TITLE}</span>
                    </a>
                    {HEADER_CONFIG.logoUrl ? (
                        <a href={HEADER_CONFIG.logoLink || '/'} class="header-avatar-link">
                            <img src={HEADER_CONFIG.logoUrl} alt="logo"/>
                        </a>
                    ) : (
                        <div class="header-avatar-nolink">
                            <div class="header-logo-placeholder">Logo</div>
                        </div>
                    )}
                </div>
                <div class="header-description" style={`color: ${topDescriptionColor};`}>
                    {HEADER_CONFIG.topDescription || SITE_DESCRIPTION}
                </div>
            </div>
        </section>
    </>
)}

<!-- 音乐播放器弹窗 -->
<div class="music-modal" id="musicModal" style="display: none;">
    <div class="music-modal-content">
        <div class="music-modal-header">
            <span>音乐播放器</span>
            <button class="close-btn" id="closeMusicModal">&times;</button>
        </div>
        <div class="music-modal-body">
            <div class="music-controls">
                <button id="playPauseBtn" class="music-btn">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" width="24" height="24">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M5.25 5.653c0-.856.917-1.398 1.667-.986l11.54 6.347a1.125 1.125 0 0 1 0 1.972l-11.54 6.347a1.125 1.125 0 0 1-1.667-.986V5.653Z" />
                    </svg>
                </button>
                <div class="music-info">
                    <p id="musicStatus">点击播放开始听音乐</p>
                </div>
            </div>
            <audio id="bgMusic" loop>
                <source src="" type="audio/mpeg">
            </audio>
        </div>
    </div>
</div>

<!-- 友链弹窗 -->
<div class="links-modal" id="linksModal" style="display: none;">
    <div class="links-modal-content">
        <div class="links-modal-header">
            <span>友情链接</span>
            <button class="close-btn" id="closeLinksModal">&times;</button>
        </div>
        <div class="links-modal-body">
            <div class="links-list">
                <a href="https://github.com" target="_blank" class="link-item">
                    <div class="link-icon">🐙</div>
                    <div class="link-info">
                        <div class="link-name">GitHub</div>
                        <div class="link-desc">全球最大的代码托管平台</div>
                    </div>
                </a>
                <a href="https://astro.build" target="_blank" class="link-item">
                    <div class="link-icon">🚀</div>
                    <div class="link-info">
                        <div class="link-name">Astro</div>
                        <div class="link-desc">快速、内容驱动的网站构建框架</div>
                    </div>
                </a>
                <a href="https://developer.mozilla.org" target="_blank" class="link-item">
                    <div class="link-icon">📚</div>
                    <div class="link-info">
                        <div class="link-name">MDN Web Docs</div>
                        <div class="link-desc">Web 开发者的权威文档</div>
                    </div>
                </a>
            </div>
        </div>
        <div class="links-modal-footer">
            <p>共 3 个链接</p>
        </div>
    </div>
</div>

<script>
    // 顶部导航栏滚动效果
    document.addEventListener('DOMContentLoaded', function() {
        const topContainer = document.getElementById('top-container');
        if (topContainer) {
            window.addEventListener('scroll', function() {
                if (window.scrollY > 50) {
                    topContainer.classList.add('scrolled');
                } else {
                    topContainer.classList.remove('scrolled');
                }
            });
        }

        // 音乐播放器功能
        const musicBtn = document.getElementById('musicBtn');
        const musicModal = document.getElementById('musicModal');
        const closeMusicModal = document.getElementById('closeMusicModal');
        const playPauseBtn = document.getElementById('playPauseBtn');
        const bgMusic = document.getElementById('bgMusic') as HTMLAudioElement | null;
        const musicStatus = document.getElementById('musicStatus');
        let isPlaying = false;

        // 打开音乐弹窗
        musicBtn?.addEventListener('click', function() {
            if (musicModal) musicModal.style.display = 'flex';
        });

        // 关闭音乐弹窗
        closeMusicModal?.addEventListener('click', function() {
            if (musicModal) musicModal.style.display = 'none';
        });

        // 点击弹窗外部关闭
        musicModal?.addEventListener('click', function(e) {
            if (e.target === musicModal && musicModal) {
                musicModal.style.display = 'none';
            }
        });

        // 播放/暂停
        playPauseBtn?.addEventListener('click', function() {
            if (isPlaying) {
                bgMusic?.pause();
                if (playPauseBtn) playPauseBtn.innerHTML = `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" width="24" height="24"><path stroke-linecap="round" stroke-linejoin="round" d="M5.25 5.653c0-.856.917-1.398 1.667-.986l11.54 6.347a1.125 1.125 0 0 1 0 1.972l-11.54 6.347a1.125 1.125 0 0 1-1.667-.986V5.653Z" /></svg>`;
                if (musicStatus) musicStatus.textContent = '已暂停';
            } else {
                bgMusic?.play().catch(e => {
                    console.log('音乐播放失败:', e);
                    if (musicStatus) musicStatus.textContent = '暂无音乐资源';
                });
                if (playPauseBtn) playPauseBtn.innerHTML = `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" width="24" height="24"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 5.25v13.5m-7.5-13.5v13.5" /></svg>`;
                if (musicStatus) musicStatus.textContent = '正在播放...';
            }
            isPlaying = !isPlaying;
        });

        // 友链弹窗功能
        const linksBtn = document.getElementById('linksBtn');
        const linksModal = document.getElementById('linksModal');
        const closeLinksModal = document.getElementById('closeLinksModal');

        // 打开友链弹窗
        linksBtn?.addEventListener('click', function() {
            if (linksModal) linksModal.style.display = 'flex';
        });

        // 关闭友链弹窗
        closeLinksModal?.addEventListener('click', function() {
            if (linksModal) linksModal.style.display = 'none';
        });

        // 点击弹窗外部关闭
        linksModal?.addEventListener('click', function(e) {
            if (e.target === linksModal && linksModal) {
                linksModal.style.display = 'none';
            }
        });
    });
</script>

<style>
    /* 音乐和友链按钮样式 */
    .tc-music, .tc-links {
        width: 40px;
        height: 40px;
        display: flex;
        justify-content: center;
        align-items: center;
        cursor: pointer;
        border-radius: 50%;
        transition: background-color 0.2s ease;
    }

    .tc-music:hover, .tc-links:hover {
        background-color: var(--color-button-hover, rgba(255,255,255,0.1));
    }

    /* 音乐播放器弹窗 */
    .music-modal, .links-modal {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: rgba(0, 0, 0, 0.5);
        z-index: 1000;
        justify-content: center;
        align-items: center;
        backdrop-filter: blur(4px);
    }

    .music-modal-content, .links-modal-content {
        background: var(--color-bg, #fff);
        border-radius: 12px;
        width: 90%;
        max-width: 400px;
        max-height: 80vh;
        overflow: hidden;
        box-shadow: 0 20px 60px rgba(0, 0, 0, 0.3);
    }

    .music-modal-header, .links-modal-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 16px 20px;
        border-bottom: 1px solid var(--color-border, #eee);
    }

    .music-modal-header span, .links-modal-header span {
        font-size: 18px;
        font-weight: 600;
        color: var(--color-text, #333);
    }

    .close-btn {
        background: none;
        border: none;
        font-size: 24px;
        cursor: pointer;
        color: var(--color-text-light, #999);
        width: 32px;
        height: 32px;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 50%;
        transition: background-color 0.2s;
    }

    .close-btn:hover {
        background-color: var(--color-button-hover, rgba(0,0,0,0.05));
    }

    .music-modal-body {
        padding: 30px 20px;
    }

    .music-controls {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 20px;
    }

    .music-btn {
        width: 60px;
        height: 60px;
        border-radius: 50%;
        border: none;
        background: var(--color-green, #07C160);
        color: white;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: transform 0.2s, box-shadow 0.2s;
    }

    .music-btn:hover {
        transform: scale(1.05);
        box-shadow: 0 4px 15px rgba(7, 193, 96, 0.4);
    }

    .music-info {
        text-align: center;
    }

    .music-info p {
        color: var(--color-text-light, #666);
        font-size: 14px;
    }

    /* 友链弹窗 */
    .links-modal-body {
        padding: 10px;
        max-height: 400px;
        overflow-y: auto;
    }

    .links-list {
        display: flex;
        flex-direction: column;
        gap: 8px;
    }

    .link-item {
        display: flex;
        align-items: center;
        padding: 12px;
        border-radius: 8px;
        text-decoration: none;
        color: inherit;
        transition: background-color 0.2s;
    }

    .link-item:hover {
        background-color: var(--color-button, #f5f5f5);
    }

    .link-icon {
        width: 40px;
        height: 40px;
        border-radius: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 20px;
        background: var(--color-button, #f0f0f0);
        margin-right: 12px;
        flex-shrink: 0;
    }

    .link-info {
        flex: 1;
        min-width: 0;
    }

    .link-name {
        font-weight: 600;
        font-size: 15px;
        color: var(--color-text, #333);
        margin-bottom: 2px;
    }

    .link-desc {
        font-size: 12px;
        color: var(--color-text-light, #999);
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .links-modal-footer {
        padding: 12px 20px;
        border-top: 1px solid var(--color-border, #eee);
        text-align: center;
    }

    .links-modal-footer p {
        font-size: 12px;
        color: var(--color-text-light, #999);
        margin: 0;
    }

    @media (prefers-color-scheme: dark) {
        .music-modal-content, .links-modal-content {
            background: var(--color-bg-dark, #1a1a1a);
        }

        .music-modal-header, .links-modal-header {
            border-bottom-color: var(--color-border-dark, #333);
        }

        .music-modal-header span, .links-modal-header span {
            color: var(--color-text-dark, #fff);
        }

        .close-btn {
            color: var(--color-text-light-dark, #888);
        }

        .link-item:hover {
            background-color: var(--color-button-dark, #2a2a2a);
        }

        .link-icon {
            background: var(--color-button-dark, #2a2a2a);
        }

        .link-name {
            color: var(--color-text-dark, #fff);
        }

        .links-modal-footer {
            border-top-color: var(--color-border-dark, #333);
        }
    }
</style>
