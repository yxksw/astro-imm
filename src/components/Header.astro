---
import { SITE_TITLE, HEADER_CONFIG } from '../consts';

interface Props {
    isHome?: boolean;
}

const { isHome = false } = Astro.props;
---

{HEADER_CONFIG.showTopBar && (
    <>
        <div class="navbar bg">
            <div class="navbar-content">
                {HEADER_CONFIG.logoUrl && (
                    <a class="site-logo" href={HEADER_CONFIG.logoLink || '/'}>
                        <img alt={SITE_TITLE} src={HEADER_CONFIG.logoUrl} style={`width: ${HEADER_CONFIG.logoSize}; height: ${HEADER_CONFIG.logoSize};`} />
                    </a>
                )}
                {HEADER_CONFIG.topTitle && (
                    <div class="site-name" style={HEADER_CONFIG.topTitleDark ? 'color: var(--color-text-fixed);' : ''}>
                        {HEADER_CONFIG.topTitle}
                    </div>
                )}
            </div>
        </div>

        <div class="navbar">
            <div class="site-description">
                {HEADER_CONFIG.topDescription && HEADER_CONFIG.topDescription}
            </div>
        </div>
    </>
)}

{!isHome && (
    <div class="back-button" title="返回">
        <a href="/" class="back-link">返回首页</a>
    </div>
)}
