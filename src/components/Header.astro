---
import { SITE_TITLE, SITE_DESCRIPTION, HEADER_CONFIG, MUSIC_CONFIG } from '../consts';

interface Props {
    isHome?: boolean;
}

const { isHome = false } = Astro.props;

// 背景图配置
const headerBgImage = HEADER_CONFIG.headerBgImage || '';
const headerBgVideo = HEADER_CONFIG.headerBgVideo || '';

// 颜色配置
const topTitleColor = HEADER_CONFIG.topTitleColor || '#ffffff';
const topDescriptionColor = HEADER_CONFIG.topDescriptionColor || '#ffffff';
const backButtonColor = HEADER_CONFIG.backButtonColor || '#ffffff';
const settingButtonColor = HEADER_CONFIG.settingButtonColor || '#ffffff';

// 音乐配置
const musicEnabled = MUSIC_CONFIG.enabled;
const musicSrc = MUSIC_CONFIG.src;
const musicName = MUSIC_CONFIG.name;
const musicAutoplay = MUSIC_CONFIG.autoplay;
const musicLoop = MUSIC_CONFIG.loop;
const musicVolume = MUSIC_CONFIG.volume;
---

{HEADER_CONFIG.showTopBar && (
    <>
        <!-- 顶部导航栏 -->
        <section class="top-container" id="top-container">
            <div class="top-container-left">
                <!-- 返回首页按钮 -->
                {!isHome && (
                    <a href="/" class="tc-back" title="返回首页" style={`color: ${backButtonColor};`}>
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" width="20" height="20">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5 3 12m0 0 7.5-7.5M3 12h18" />
                        </svg>
                    </a>
                )}
                {musicEnabled && (
                    <!-- 音乐按钮 -->
                    <div class="tc-music" id="musicBtn" title={`音乐播放器 - ${musicName}`} style={`color: ${backButtonColor};`}>
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" width="20" height="20">
                            <path stroke-linecap="round" stroke-linejoin="round" d="m9 9 10.5-3m0 6.553v3.75a2.25 2.25 0 0 1-1.632 2.163l-1.32.377a1.803 1.803 0 1 1-.99-3.467l2.31-.66a2.25 2.25 0 0 0 1.632-2.163Zm0 0V2.25L9 5.25v10.303m0 0v3.75a2.25 2.25 0 0 1-1.632 2.163l-1.32.377a1.803 1.803 0 0 1-.99-3.467l2.31-.66A2.25 2.25 0 0 0 9 15.553Z" />
                        </svg>
                    </div>
                )}
                <!-- 友链按钮 -->
                <div class="tc-friends" id="friendsBtn" title="友情链接" style={`color: ${backButtonColor};`}>
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" width="20" height="20">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M13.19 8.688a4.5 4.5 0 0 1 1.242 7.244l-4.5 4.5a4.5 4.5 0 0 1-6.364-6.364l1.757-1.757m13.35-.622 1.757-1.757a4.5 4.5 0 0 0-6.364-6.364l-4.5 4.5a4.5 4.5 0 0 0 1.242 7.244" />
                    </svg>
                </div>
            </div>
            <div class="top-container-right">
                <!-- 设置图标 - 点击跳转到编辑页面 -->
                <a href="/admin/editor" class="tc-setting" title="编辑文章" style={`color: ${settingButtonColor};`}>
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" width="20" height="20">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M9.594 3.94c.09-.542.56-.94 1.11-.94h2.593c.55 0 1.02.398 1.11.94l.213 1.281c.063.374.313.686.645.87.074.04.147.083.22.127.324.196.72.257 1.075.124l1.217-.456a1.125 1.125 0 0 1 1.37.49l1.296 2.247a1.125 1.125 0 0 1-.26 1.431l-1.003.827c-.293.24-.438.613-.431.992a6.759 6.759 0 0 1 0 .255c-.007.378.138.75.43.99l1.005.828c.424.35.534.954.26 1.43l-1.298 2.247a1.125 1.125 0 0 1-1.369.491l-1.217-.456c-.355-.133-.75-.072-1.076.124a6.57 6.57 0 0 1-.22.128c-.331.183-.581.495-.644.869l-.212 1.28c-.09.543-.56.941-1.11.941h-2.594c-.55 0-1.02-.398-1.11-.94l-.213-1.281c-.063-.374-.313-.686-.645-.87a6.519 6.519 0 0 1-.22-.127c-.325-.196-.72-.257-1.076-.124l-1.217.456a1.125 1.125 0 0 1-1.369-.49l-1.296-2.247a1.125 1.125 0 0 1 .26-1.431l1.004-.827c.292-.24.437-.613.43-.992a6.932 6.932 0 0 1 0-.255c.007-.378-.138-.75-.43-.99l-1.004-.828a1.125 1.125 0 0 1-.26-1.43l1.296-2.247a1.125 1.125 0 0 1 1.37-.491l1.216.456c.356.133.751.072 1.076-.124.072-.044.146-.087.22-.128.332-.183.582-.495.644-.869l.214-1.281Z" />
                        <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" />
                    </svg>
                </a>
            </div>
        </section>

        <!-- 头部横幅 -->
        <section class="header-container" style={headerBgImage ? `background-image: url(${headerBgImage});` : headerBgVideo ? '' : 'background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);'}>
            {headerBgVideo && (
                <video src={headerBgVideo} autoplay muted loop playsinline></video>
            )}

            <div class="header-info">
                <div class="header-user">
                    <a href={HEADER_CONFIG.logoLink || '/'} class="header-site-title" style={`color: ${topTitleColor};`}>
                        <span>{HEADER_CONFIG.topTitle || SITE_TITLE}</span>
                    </a>
                    {HEADER_CONFIG.logoUrl ? (
                        <a href={HEADER_CONFIG.logoLink || '/'} class="header-avatar-link">
                            <img src={HEADER_CONFIG.logoUrl} alt="logo"/>
                        </a>
                    ) : (
                        <div class="header-avatar-nolink">
                            <div class="header-logo-placeholder">Logo</div>
                        </div>
                    )}
                </div>
                <div class="header-description" style={`color: ${topDescriptionColor};`}>
                    {HEADER_CONFIG.topDescription || SITE_DESCRIPTION}
                </div>
            </div>
        </section>
    </>
)}

<!-- 音乐播放器弹窗 -->
<div class="music-modal" id="musicModal" style="display: none;">
    <div class="music-modal-content">
        <div class="music-modal-header">
            <span>音乐播放器</span>
            <button class="close-btn" id="closeMusicModal">&times;</button>
        </div>
        <div class="music-modal-body">
            <div class="music-controls">
                <button id="playPauseBtn" class="music-btn">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" width="24" height="24">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M5.25 5.653c0-.856.917-1.398 1.667-.986l11.54 6.347a1.125 1.125 0 0 1 0 1.972l-11.54 6.347a1.125 1.125 0 0 1-1.667-.986V5.653Z" />
                    </svg>
                </button>
                <div class="music-info">
                    <p id="musicStatus">点击播放开始听音乐</p>
                </div>
            </div>
            <audio id="bgMusic" loop={musicLoop} autoplay={musicAutoplay} data-volume={musicVolume}>
                <source src={musicSrc} type="audio/mpeg">
            </audio>
        </div>
    </div>
</div>

<!-- 友链弹窗 -->
<div class="friends-modal" id="friendsModal" style="display: none;">
    <div class="friends-modal-content">
        <div class="friends-modal-header">
            <span>友情链接</span>
            <button class="close-btn" id="closeFriendsModal">&times;</button>
        </div>
        <div class="friends-modal-body">
            <div class="friends-container" id="friendsContainer">
                <div class="friends-loading">加载中...</div>
            </div>
        </div>
        <div class="friends-modal-footer">
            <p id="friendsCount">共 0 个链接</p>
        </div>
    </div>
</div>

<script>
    // 顶部导航栏滚动效果
    document.addEventListener('DOMContentLoaded', function() {
        const topContainer = document.getElementById('top-container');
        if (topContainer) {
            window.addEventListener('scroll', function() {
                if (window.scrollY > 50) {
                    topContainer.classList.add('scrolled');
                } else {
                    topContainer.classList.remove('scrolled');
                }
            });
        }

        // 音乐播放器功能
        const musicBtn = document.getElementById('musicBtn');
        const musicModal = document.getElementById('musicModal');
        const closeMusicModal = document.getElementById('closeMusicModal');
        const playPauseBtn = document.getElementById('playPauseBtn');
        const bgMusic = document.getElementById('bgMusic') as HTMLAudioElement | null;
        const musicStatus = document.getElementById('musicStatus');
        let isPlaying = false;

        // 打开音乐弹窗
        musicBtn?.addEventListener('click', function() {
            if (musicModal) musicModal.style.display = 'flex';
        });

        // 关闭音乐弹窗
        closeMusicModal?.addEventListener('click', function() {
            if (musicModal) musicModal.style.display = 'none';
        });

        // 点击弹窗外部关闭
        musicModal?.addEventListener('click', function(e) {
            if (e.target === musicModal && musicModal) {
                musicModal.style.display = 'none';
            }
        });

        // 播放/暂停
        playPauseBtn?.addEventListener('click', function() {
            if (isPlaying) {
                bgMusic?.pause();
                if (playPauseBtn) playPauseBtn.innerHTML = `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" width="24" height="24"><path stroke-linecap="round" stroke-linejoin="round" d="M5.25 5.653c0-.856.917-1.398 1.667-.986l11.54 6.347a1.125 1.125 0 0 1 0 1.972l-11.54 6.347a1.125 1.125 0 0 1-1.667-.986V5.653Z" /></svg>`;
                if (musicStatus) musicStatus.textContent = '已暂停';
            } else {
                bgMusic?.play().catch(e => {
                    console.log('音乐播放失败:', e);
                    if (musicStatus) musicStatus.textContent = '暂无音乐资源';
                });
                if (playPauseBtn) playPauseBtn.innerHTML = `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" width="24" height="24"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 5.25v13.5m-7.5-13.5v13.5" /></svg>`;
                if (musicStatus) musicStatus.textContent = '正在播放...';
            }
            isPlaying = !isPlaying;
        });

        // 友链功能
        const friendsBtn = document.getElementById('friendsBtn');
        const friendsModal = document.getElementById('friendsModal');
        const closeFriendsModal = document.getElementById('closeFriendsModal');
        const friendsContainer = document.getElementById('friendsContainer');
        const friendsCount = document.getElementById('friendsCount');
        let friendsData: any[] = [];

        // 打开友链弹窗
        friendsBtn?.addEventListener('click', function() {
            if (friendsModal) friendsModal.style.display = 'flex';
            // 如果还没有加载过数据，则加载
            if (friendsData.length === 0 && friendsContainer) {
                loadFriends();
            }
        });

        // 关闭友链弹窗
        closeFriendsModal?.addEventListener('click', function() {
            if (friendsModal) friendsModal.style.display = 'none';
        });

        // 点击弹窗外部关闭
        friendsModal?.addEventListener('click', function(e) {
            if (e.target === friendsModal && friendsModal) {
                friendsModal.style.display = 'none';
            }
        });

        // 加载友链数据
        async function loadFriends() {
            if (!friendsContainer) return;
            
            try {
                const response = await fetch('https://friends-api.050815.xyz/data/friends.json');
                if (!response.ok) {
                    if (response.status === 401) {
                        throw new Error('认证失败或链接已失效');
                    }
                    throw new Error(`HTTP 错误：${response.status}`);
                }
                const data = await response.json();
                friendsData = Array.isArray(data) ? data : (data.friends || data.data || []);
                
                // 渲染友链列表
                renderFriends(friendsData);
            } catch (error) {
                console.error('加载友链失败:', error);
                if (friendsContainer) {
                    const errorMessage = error instanceof Error ? error.message : '未知错误';
                    friendsContainer.innerHTML = `
                        <div class="friends-error">
                            <p>加载失败：${errorMessage}</p>
                            <button id="retryFriendsBtn" class="retry-btn">重试</button>
                        </div>
                    `;
                    // 添加重试按钮事件
                    const retryBtn = document.getElementById('retryFriendsBtn');
                    retryBtn?.addEventListener('click', loadFriends);
                }
            }
        }

        // 渲染友链列表
        function renderFriends(friends: any[]) {
            if (!friendsContainer || !friendsCount) return;
            
            console.log('渲染友链，数量:', friends.length);
            console.log('友链数据:', friends);
            
            if (friends.length === 0) {
                friendsContainer.innerHTML = '<div class="friends-empty">暂无友链</div>';
                friendsCount.textContent = '共 0 个链接';
                return;
            }

            const html = friends.map((friend: any, index: number) => {
                const url = friend.url || friend.link || '#';
                const avatar = friend.avatar || friend.logo || '';
                const name = friend.name || '未知名称';
                const description = friend.description || friend.desc || '';
                
                console.log(`渲染第${index + 1}个友链:`, { url, name, avatar });
                
                return `
                    <a href="${url}" target="_blank" class="friend-item" style="display: block; text-decoration: none; color: inherit; background: var(--color-background, #f5f5f5); border-radius: 12px; padding: 16px; transition: all 0.3s ease; margin-bottom: 8px;">
                        <div class="friend-content" style="display: flex; align-items: center; gap: 12px;">
                            <img src="${avatar}" alt="${name}" class="friend-avatar" style="width: 40px; height: 40px; border-radius: 50%; object-fit: cover; flex-shrink: 0; border: 2px solid var(--color-green, #07C160); background: #fff;" onerror="this.src='data:image/svg+xml;base64,'">
                            <div class="friend-info" style="flex: 1; overflow: hidden; min-width: 0;">
                                <p class="friend-name" style="font-size: 15px; font-weight: 600; color: var(--color-text, #333); margin: 0 0 4px 0; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">${name}</p>
                                ${description ? `<span class="friend-description" style="font-size: 12px; color: var(--color-text-light, #999); display: block; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; line-height: 1.4;">${description}</span>` : ''}
                            </div>
                            <svg class="friend-arrow" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" width="18" height="18" style="color: var(--color-text-light, #ccc); flex-shrink: 0; transition: transform 0.3s ease;">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5" />
                            </svg>
                        </div>
                    </a>
                `;
            }).join('');

            console.log('生成的 HTML:', html.substring(0, 200) + '...');
            friendsContainer.innerHTML = html;
            friendsCount.textContent = `共${friends.length}个链接`;
            
            // 添加全局样式支持悬停效果
            if (!document.getElementById('friends-global-styles')) {
                const style = document.createElement('style');
                style.id = 'friends-global-styles';
                style.textContent = `
                    .friend-item {
                        transition: all 0.3s ease !important;
                    }
                    .friend-item:hover {
                        transform: translateY(-2px) !important;
                        box-shadow: 0 8px 24px rgba(0, 0, 0, 0.12) !important;
                        background: var(--color-background-hover, #e8e8e8) !important;
                    }
                    .friend-item:hover .friend-arrow {
                        transform: translateX(4px) !important;
                        color: var(--color-green, #07C160) !important;
                    }
                    @media (prefers-color-scheme: dark) {
                        .friend-item {
                            background: var(--color-background-dark, #2a2a2a) !important;
                            border: 1px solid var(--color-border-dark, #333) !important;
                        }
                        .friend-item:hover {
                            background: var(--color-background-hover-dark, #333) !important;
                            border-color: var(--color-green, #07C160) !important;
                        }
                        .friend-avatar {
                            background: var(--color-bg-dark, #1a1a1a) !important;
                            border-color: var(--color-green, #07C160) !important;
                        }
                        .friend-name {
                            color: var(--color-text-dark, #fff) !important;
                        }
                        .friend-description {
                            color: var(--color-text-light-dark, #aaa) !important;
                        }
                        .friend-arrow {
                            color: var(--color-text-light-dark, #666) !important;
                        }
                        .friend-item:hover .friend-arrow {
                            color: var(--color-green, #07C160) !important;
                        }
                    }
                `;
                document.head.appendChild(style);
            }
        }
    });
</script>

<style>
    /* 音乐按钮样式 */
    .tc-music {
        width: 40px;
        height: 40px;
        display: flex;
        justify-content: center;
        align-items: center;
        cursor: pointer;
        border-radius: 50%;
        transition: background-color 0.2s ease;
    }

    .tc-music:hover {
        background-color: var(--color-button-hover, rgba(255,255,255,0.1));
    }

    /* 友链按钮样式 */
    /* eslint-disable-next-line @typescript-eslint/no-unused-vars */
    .tc-friends {
        width: 40px;
        height: 40px;
        display: flex;
        justify-content: center;
        align-items: center;
        cursor: pointer;
        border-radius: 50%;
        transition: background-color 0.2s ease;
    }

    .tc-friends:hover {
        background-color: var(--color-button-hover, rgba(255,255,255,0.1));
    }

    /* 音乐播放器弹窗 */
    .music-modal {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: rgba(0, 0, 0, 0.5);
        z-index: 1000;
        justify-content: center;
        align-items: center;
        backdrop-filter: blur(4px);
    }

    .music-modal-content {
        background: var(--color-bg, #fff);
        border-radius: 12px;
        width: 90%;
        max-width: 400px;
        max-height: 80vh;
        overflow: hidden;
        box-shadow: 0 20px 60px rgba(0, 0, 0, 0.3);
    }

    .music-modal-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 16px 20px;
        border-bottom: 1px solid var(--color-border, #eee);
    }

    .music-modal-header span {
        font-size: 18px;
        font-weight: 600;
        color: var(--color-text, #333);
    }

    .close-btn {
        background: none;
        border: none;
        font-size: 24px;
        cursor: pointer;
        color: var(--color-text-light, #999);
        width: 32px;
        height: 32px;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 50%;
        transition: background-color 0.2s;
    }

    .close-btn:hover {
        background-color: var(--color-button-hover, rgba(0,0,0,0.05));
    }

    .music-modal-body {
        padding: 30px 20px;
    }

    .music-controls {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 20px;
    }

    .music-btn {
        width: 60px;
        height: 60px;
        border-radius: 50%;
        border: none;
        background: var(--color-green, #07C160);
        color: white;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: transform 0.2s, box-shadow 0.2s;
    }

    .music-btn:hover {
        transform: scale(1.05);
        box-shadow: 0 4px 15px rgba(7, 193, 96, 0.4);
    }

    .music-info {
        text-align: center;
    }

    .music-info p {
        color: var(--color-text-light, #666);
        font-size: 14px;
    }

    /* 友链弹窗 */
    .friends-modal {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: rgba(0, 0, 0, 0.5);
        z-index: 1000;
        justify-content: center;
        align-items: center;
        backdrop-filter: blur(4px);
        display: none;
    }

    .friends-modal.show {
        display: flex;
    }

    .friends-modal-content {
        background: var(--color-bg, #fff);
        border-radius: 16px;
        width: 90%;
        max-width: 500px;
        max-height: 80vh;
        overflow: hidden;
        box-shadow: 0 20px 60px rgba(0, 0, 0, 0.3);
        display: flex;
        flex-direction: column;
    }

    .friends-modal-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 20px;
        border-bottom: 2px solid var(--color-green, #07C160);
    }

    .friends-modal-header span {
        font-size: 20px;
        font-weight: 700;
        color: var(--color-text, #333);
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .friends-modal-header span::before {
        content: '👥';
        font-size: 24px;
    }

    .friends-modal-body {
        padding: 20px;
        overflow-y: auto;
        flex: 1;
        min-height: 200px;
        max-height: calc(80vh - 140px);
    }

    .friends-modal-footer {
        padding: 12px 20px;
        border-top: 1px solid var(--color-border, #eee);
        text-align: center;
        flex-shrink: 0;
        background: var(--color-background, #f5f5f5);
    }

    .friends-modal-footer p {
        color: var(--color-text-light, #999);
        font-size: 12px;
        margin: 0;
    }

    .friends-loading,
    .friends-error,
    .friends-empty {
        text-align: center;
        padding: 60px 20px;
        color: var(--color-text-light, #999);
        font-size: 14px;
    }

    .friends-error p {
        margin: 0 0 15px 0;
        line-height: 1.5;
    }

    .retry-btn {
        padding: 10px 24px;
        background: var(--color-green, #07C160);
        color: white;
        border: none;
        border-radius: 8px;
        font-size: 14px;
        cursor: pointer;
        transition: all 0.3s ease;
        box-shadow: 0 4px 12px rgba(7, 193, 96, 0.3);
    }

    .retry-btn:hover {
        transform: translateY(-2px);
        box-shadow: 0 6px 20px rgba(7, 193, 96, 0.4);
    }

    /* 友链卡片样式 - 通过 JS 动态添加全局样式 */

