---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import PostCard from '../components/PostCard.astro';
import { SITE_TITLE, SITE_DESCRIPTION, NAV_LINKS } from '../consts';

// 获取所有博客文章，按日期排序
const posts = (await getCollection('blog')).sort(
    (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

// 分离置顶文章和普通文章
const topPosts = posts.filter(post => post.data.isTop);
const normalPosts = posts.filter(post => !post.data.isTop);
const allPosts = [...topPosts, ...normalPosts];
---

<BaseLayout title={SITE_TITLE} description={SITE_DESCRIPTION} isHome={true}>
    <!-- 欢迎区域/导航 -->
    <article class="post welcome-post">
        <div class="author-avatar">
            <img
                alt="异飨客"
                loading="lazy"
                fetchpriority="low"
                src="https://cdn.jsdmirror.com/gh/zsxcoder/github-img@main/img/yxk-avatar.avif">
        </div>
        <div class="content">
            <div class="post-info">
                <div class="author-name">
                    异飨客
                    <div class="author-badge" style="background: #ff4757; color: white;">导航</div>
                </div>
            </div>
            <div class="text">
                <p class="more">
                    {NAV_LINKS.map((link, index) => (
                        <>
                            <a href={link.href}>{link.text}</a>
                            {index < NAV_LINKS.length - 1 ? ' | ' : ''}
                        </>
                    ))}
                </p>
            </div>
            <div class="post-meta">
                <div class="post-position"></div>
                <div class="date">
                    最近一次构建于 {new Date().toLocaleString('zh-CN', { month: '2-digit', day: '2-digit', hour: '2-digit', minute: '2-digit' }).replace(/\//g, '/')}
                </div>
            </div>
        </div>
    </article>

    <!-- 置顶文章列表（最多 3 篇） -->
    {topPosts.slice(0, 3).map(post => (
        <PostCard 
            title={post.data.title}
            description={post.data.description}
            pubDate={post.data.pubDate}
            updatedDate={post.data.updatedDate}
            slug={post.slug}
            isAdvertise={post.data.isAdvertise}
            position={post.data.position}
            positionUrl={post.data.positionUrl}
            isTop={true}
        />
    ))}

    <!-- 普通文章列表 -->
    {normalPosts.map((post, index) => (
        <PostCard 
            title={post.data.title}
            description={post.data.description}
            pubDate={post.data.pubDate}
            updatedDate={post.data.updatedDate}
            slug={post.slug}
            isAdvertise={post.data.isAdvertise}
            position={post.data.position}
            positionUrl={post.data.positionUrl}
        />
    ))}
    
    {allPosts.length === 0 && (
        <div class="no-more-posts">
            还没有文章，开始写博客吧！
        </div>
    )}
</BaseLayout>
