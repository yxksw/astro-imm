---
import { SITE_TITLE } from '../../consts';
import { getCollection } from 'astro:content';

// 在构建时获取所有文章数据
let allPosts: any[] = [];
try {
    allPosts = await getCollection('blog');
} catch (e) {
    console.error('Failed to load posts:', e);
}

// 序列化文章数据供客户端使用
const postsData = allPosts.map(p => ({
    slug: p.slug,
    title: p.data.title,
    description: p.data.description,
    pubDate: p.data.pubDate,
    position: p.data.position,
    positionUrl: p.data.positionUrl,
    isTop: p.data.isTop,
    isAdvertise: p.data.isAdvertise,
    body: p.body
}));
---

<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>文章编辑器 | {SITE_TITLE}</title>
    <style>
        /* ========================================
           CSS 变量
           ======================================== */
        :root {
            --main-background: #ffffff;
            --body-background: #f0f0f0;
            --primary-background: #F7F7F7;
            --primary-background-hover: #DEDEDE;
            --text-color: #333333;
            --text-sub-color: #555555;
            --line: rgb(243 244 246 / 1);
            --link: #576b95;
            --green: rgb(7 193 96);
        }

        @media (prefers-color-scheme: dark) {
            :root {
                --main-background: #262626;
                --body-background: #181818;
                --primary-background: #323232;
                --primary-background-hover: #434343;
                --text-color: #aaaaaa;
                --text-sub-color: #888;
                --line: #333333;
            }
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            background-color: var(--body-background);
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
            min-height: 100vh;
        }

        /* ========================================
           顶部栏
           ======================================== */
        .edit-top-bar {
            position: fixed;
            top: 0;
            left: 50%;
            transform: translateX(-50%);
            width: 100%;
            max-width: 576px;
            height: 56px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 0 15px;
            background: var(--main-background);
            border-bottom: 1px solid var(--line);
            z-index: 100;
        }

        .edit-back-btn {
            display: flex;
            align-items: center;
            justify-content: center;
            width: 36px;
            height: 36px;
            border-radius: 50%;
            color: var(--text-color);
            text-decoration: none;
            transition: background-color 0.2s ease;
            cursor: pointer;
            border: none;
            background: transparent;
        }

        .edit-back-btn:hover {
            background: var(--primary-background);
        }

        .edit-publish-btn {
            padding: 6px 16px;
            background: #07C160;
            color: #fff;
            border: none;
            border-radius: 4px;
            font-size: 14px;
            font-weight: 500;
            cursor: pointer;
            transition: all 0.2s ease;
        }

        .edit-publish-btn:hover {
            background: #06AD56;
        }

        .edit-publish-btn:disabled {
            background: #ccc;
            cursor: not-allowed;
        }

        /* ========================================
           主容器
           ======================================== */
        .edit-container {
            max-width: 576px;
            margin: 0 auto;
            padding-top: 56px;
            min-height: 100vh;
            background: var(--main-background);
        }

        /* ========================================
           内容输入区
           ======================================== */
        .edit-content-area {
            width: 100%;
            padding: 15px;
        }

        .edit-content-area input[type="text"] {
            width: 100%;
            border: none;
            outline: none;
            font-size: 18px;
            font-weight: 600;
            color: var(--text-color);
            background: transparent;
            margin-bottom: 10px;
            font-family: inherit;
        }

        .edit-content-area input[type="text"]::placeholder {
            color: #b2b2b2;
        }

        .edit-content-area textarea {
            width: 100%;
            min-height: 150px;
            border: none;
            outline: none;
            resize: none;
            font-size: 16px;
            line-height: 1.6;
            color: var(--text-color);
            background: transparent;
            font-family: inherit;
        }

        .edit-content-area textarea::placeholder {
            color: #b2b2b2;
        }

        /* ========================================
           功能选项区
           ======================================== */
        .edit-options {
            width: 100%;
            border-top: 8px solid var(--body-background);
        }

        .edit-option-item {
            display: flex;
            align-items: center;
            padding: 14px 15px;
            border-bottom: 1px solid var(--line);
            cursor: pointer;
            transition: background-color 0.2s ease;
        }

        .edit-option-item:hover {
            background: var(--primary-background);
        }

        .edit-option-item:last-child {
            border-bottom: none;
        }

        .option-icon {
            width: 28px;
            display: flex;
            align-items: center;
            justify-content: flex-start;
            color: var(--text-sub-color);
            margin-right: 10px;
        }

        .option-content {
            flex: 1;
        }

        .option-label {
            font-size: 15px;
            color: var(--text-color);
        }

        .option-value {
            font-size: 14px;
            color: var(--text-sub-color);
            margin-right: 8px;
        }

        .option-arrow {
            color: var(--text-sub-color);
        }

        .option-input {
            flex: 1;
            border: none;
            outline: none;
            font-size: 15px;
            color: var(--text-color);
            background: transparent;
            font-family: inherit;
        }

        .option-input::placeholder {
            color: #b2b2b2;
        }

        /* 开关样式 */
        .option-switch {
            position: relative;
            width: 50px;
            height: 28px;
        }

        .option-switch input {
            opacity: 0;
            width: 0;
            height: 0;
        }

        .slider {
            position: absolute;
            cursor: pointer;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background-color: #ccc;
            transition: .3s;
            border-radius: 28px;
        }

        .slider:before {
            position: absolute;
            content: "";
            height: 22px;
            width: 22px;
            left: 3px;
            bottom: 3px;
            background-color: white;
            transition: .3s;
            border-radius: 50%;
        }

        input:checked + .slider {
            background-color: #07C160;
        }

        input:checked + .slider:before {
            transform: translateX(22px);
        }

        /* 深色模式开关样式 */
        @media (prefers-color-scheme: dark) {
            .slider {
                background-color: #555;
            }

            .slider:before {
                background-color: #ddd;
            }

            input:checked + .slider {
                background-color: #07C160;
            }

            input:checked + .slider:before {
                background-color: white;
            }
        }

        /* 展开的面板 */
        .edit-panel {
            padding: 15px;
            background: var(--primary-background);
            border-bottom: 1px solid var(--line);
        }

        .edit-panel input {
            width: 100%;
            padding: 10px;
            border: 1px solid var(--line);
            border-radius: 4px;
            font-size: 14px;
            margin-bottom: 10px;
            background: var(--main-background);
            color: var(--text-color);
            font-family: inherit;
        }

        .edit-panel input:focus {
            outline: none;
            border-color: #07C160;
        }

        /* 日期选择器深色模式适配 */
        input[type="date"].option-input {
            background-color: var(--main-background);
            color: var(--text-color);
            border: none;
            padding: 0;
            font-family: inherit;
        }

        input[type="date"]::-webkit-calendar-picker-indicator {
            filter: invert(0.4);
            cursor: pointer;
        }

        @media (prefers-color-scheme: dark) {
            input[type="date"]::-webkit-calendar-picker-indicator {
                filter: invert(0.7);
            }
        }

        /* ========================================
           状态提示
           ======================================== */
        .edit-status {
            position: fixed;
            bottom: 30px;
            left: 50%;
            transform: translateX(-50%);
            background: rgba(0, 0, 0, 0.8);
            color: #fff;
            padding: 12px 24px;
            border-radius: 4px;
            font-size: 14px;
            z-index: 200;
            opacity: 0;
            transition: opacity 0.3s ease;
            pointer-events: none;
        }

        .edit-status.show {
            opacity: 1;
        }

        /* ========================================
           隐藏的元素
           ======================================== */
        .hidden {
            display: none !important;
        }
    </style>
</head>
<body>
    <!-- 顶部栏 -->
    <section class="edit-top-bar">
        <div class="edit-top-left">
            <button type="button" class="edit-back-btn" onclick="history.back()">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" width="20" height="20">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5 8.25 12l7.5-7.5" />
                </svg>
            </button>
        </div>
        <div class="edit-top-right">
            <button type="button" class="edit-publish-btn" id="publishBtn">发表</button>
        </div>
    </section>

    <section class="edit-container">
        <form id="editForm">
            <!-- 内容输入区 -->
            <div class="edit-content-area">
                <input type="text" id="postTitle" placeholder="标题" value="">
                <textarea id="postContent" placeholder="这一刻的想法..." rows="6"></textarea>
            </div>

            <!-- 功能选项区 -->
            <div class="edit-options">
                <!-- 所在位置 -->
                <div class="edit-option-item" onclick="togglePanel('locationPanel')">
                    <div class="option-icon">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" width="22" height="22">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" />
                            <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z" />
                        </svg>
                    </div>
                    <div class="option-content">
                        <span class="option-label" id="locationLabel">所在位置</span>
                    </div>
                    <div class="option-arrow">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" width="16" height="16">
                            <path stroke-linecap="round" stroke-linejoin="round" d="m8.25 4.5 7.5 7.5-7.5 7.5" />
                        </svg>
                    </div>
                </div>

                <!-- 位置面板 -->
                <div id="locationPanel" class="edit-panel hidden">
                    <input type="text" id="postPosition" placeholder="输入位置名称">
                    <input type="url" id="postPositionUrl" placeholder="输入跳转地址(选填)">
                </div>

                <!-- 日期 -->
                <div class="edit-option-item">
                    <div class="option-icon">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" width="22" height="22">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 0 1 2.25-2.25h13.5A2.25 2.25 0 0 1 21 7.5v11.25m-18 0A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75m-18 0v-7.5A2.25 2.25 0 0 1 5.25 9h13.5A2.25 2.25 0 0 1 21 11.25v7.5" />
                        </svg>
                    </div>
                    <div class="option-content">
                        <input type="date" id="postDate" class="option-input" style="flex: 1;">
                    </div>
                </div>

                <!-- 置顶文章 -->
                <div class="edit-option-item">
                    <div class="option-icon">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" width="22" height="22">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M15.362 5.214A8.252 8.252 0 0 1 12 21 8.25 8.25 0 0 1 6.038 7.047 8.287 8.287 0 0 0 9 9.601a8.983 8.983 0 0 1 3.361-6.867 8.21 8.21 0 0 0 3 2.48Z" />
                            <path stroke-linecap="round" stroke-linejoin="round" d="M12 18a3.75 3.75 0 0 0 .495-7.468 5.99 5.99 0 0 0-1.925 3.547 5.975 5.975 0 0 1-2.133-1.001A3.75 3.75 0 0 0 12 18Z" />
                        </svg>
                    </div>
                    <div class="option-content">
                        <span class="option-label">置顶文章</span>
                    </div>
                    <div class="option-switch">
                        <label class="switch">
                            <input type="checkbox" id="postIsTop">
                            <span class="slider"></span>
                        </label>
                    </div>
                </div>

                <!-- 广告标记 -->
                <div class="edit-option-item">
                    <div class="option-icon">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" width="22" height="22">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M10.34 15.84c-.688-.06-1.386-.09-2.09-.09H7.5a4.5 4.5 0 1 1 0-9h.75c.704 0 1.402-.03 2.09-.09m0 9.18c.253.962.584 1.892.985 2.783.247.55.06 1.21-.463 1.511l-.657.38c-.551.318-1.26.117-1.527-.461a20.845 20.845 0 0 1-1.44-4.282m3.102.069a18.03 18.03 0 0 1-.59-4.59c0-1.586.205-3.124.59-4.59m0 9.18a23.848 23.848 0 0 1 8.835 2.535M10.34 6.66a23.847 23.847 0 0 0 8.835-2.535m0 0A23.74 23.74 0 0 0 18.795 3m.38 1.125a23.91 23.91 0 0 1 1.014 5.395m-1.014 8.855c-.118.38-.245.754-.38 1.125m.38-1.125a23.91 23.91 0 0 0 1.014-5.395m0-3.46c.495.413.811 1.035.811 1.73 0 .695-.316 1.317-.811 1.73m0-3.46a24.347 24.347 0 0 1 0 3.46" />
                        </svg>
                    </div>
                    <div class="option-content">
                        <span class="option-label">广告内容</span>
                    </div>
                    <div class="option-switch">
                        <label class="switch">
                            <input type="checkbox" id="postIsAdvertise">
                            <span class="slider"></span>
                        </label>
                    </div>
                </div>
            </div>

            <!-- 隐藏字段 -->
            <input type="hidden" id="postSha" value="">
            <input type="hidden" id="postSlug" value="">
        </form>
    </section>

    <!-- 状态提示 -->
    <div id="editStatus" class="edit-status"></div>

    <script define:vars={{ postsData }}>

        // 切换面板显示
        function togglePanel(panelId) {
            const panel = document.getElementById(panelId);
            if (panel) {
                panel.classList.toggle('hidden');
            }
        }

        // 显示状态提示
        function showStatus(message) {
            const status = document.getElementById('editStatus');
            status.textContent = message;
            status.classList.add('show');
            setTimeout(() => {
                status.classList.remove('show');
            }, 2000);
        }

        // 生成 frontmatter
        function generateFrontmatter(data) {
            const frontmatter = {
                title: data.title,
                description: data.description || '',
                pubDate: data.pubDate,
            };

            if (data.isTop) frontmatter.isTop = true;
            if (data.isAdvertise) frontmatter.isAdvertise = true;
            if (data.position) frontmatter.position = data.position;
            if (data.positionUrl) frontmatter.positionUrl = data.positionUrl;

            const yaml = Object.entries(frontmatter)
                .map(([key, value]) => {
                    if (typeof value === 'string') {
                        return `${key}: '${value.replace(/'/g, "''")}'`;
                    }
                    return `${key}: ${value}`;
                })
                .join('\n');

            return `---\n${yaml}\n---\n\n`;
        }

        // 保存文章
        async function savePost() {
            const title = document.getElementById('postTitle').value.trim();
            const content = document.getElementById('postContent').value.trim();

            if (!title || !content) {
                showStatus('请输入标题和内容');
                return;
            }

            const data = {
                title: title,
                description: content.slice(0, 100).replace(/\n/g, ' '),
                slug: document.getElementById('postSlug').value || title.toLowerCase().replace(/[^a-z0-9\u4e00-\u9fa5]+/g, '-').replace(/^-|-$/g, ''),
                pubDate: document.getElementById('postDate').value || new Date().toISOString().split('T')[0],
                position: document.getElementById('postPosition').value,
                positionUrl: document.getElementById('postPositionUrl').value,
                isTop: document.getElementById('postIsTop').checked,
                isAdvertise: document.getElementById('postIsAdvertise').checked,
                content: content,
                sha: document.getElementById('postSha').value
            };

            const fullContent = generateFrontmatter(data) + data.content;
            const path = `src/content/blog/${data.slug}.md`;

            const publishBtn = document.getElementById('publishBtn');
            publishBtn.disabled = true;
            publishBtn.textContent = '保存中...';

            try {
                const response = await fetch('/api/github/posts', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        path,
                        content: fullContent,
                        message: data.sha ? `Update: ${data.title}` : `Create: ${data.title}`,
                        sha: data.sha || undefined,
                    }),
                });

                const result = await response.json();

                if (result.error) {
                    showStatus('保存失败: ' + result.error);
                    publishBtn.disabled = false;
                    publishBtn.textContent = data.sha ? '保存' : '发表';
                } else {
                    showStatus('保存成功！');
                    document.getElementById('postSha').value = result.content.sha;
                    document.getElementById('postSlug').value = data.slug;
                    publishBtn.textContent = '保存';
                    setTimeout(() => {
                        window.location.href = `/blog/${data.slug}`;
                    }, 1000);
                }
            } catch (error) {
                showStatus('保存失败');
                publishBtn.disabled = false;
                publishBtn.textContent = data.sha ? '保存' : '发表';
                console.error(error);
            }
        }

        // 初始化
        document.addEventListener('DOMContentLoaded', () => {
            // 从 URL 获取 slug
            const urlParams = new URLSearchParams(window.location.search);
            const editSlug = urlParams.get('slug');

            // 查找文章
            const post = editSlug ? postsData.find(p => p.slug === editSlug) : null;

            if (post) {
                // 填充表单
                document.getElementById('postTitle').value = post.title || '';
                document.getElementById('postContent').value = post.body || '';
                document.getElementById('postSlug').value = post.slug || '';
                document.getElementById('postDate').value = post.pubDate ? new Date(post.pubDate).toISOString().split('T')[0] : new Date().toISOString().split('T')[0];
                document.getElementById('postPosition').value = post.position || '';
                document.getElementById('postPositionUrl').value = post.positionUrl || '';
                document.getElementById('postIsTop').checked = post.isTop || false;
                document.getElementById('postIsAdvertise').checked = post.isAdvertise || false;

                // 更新位置标签
                if (post.position) {
                    document.getElementById('locationLabel').textContent = post.position;
                }

                // 更新按钮文字
                document.getElementById('publishBtn').textContent = '保存';
            } else {
                // 新建文章，设置默认日期
                document.getElementById('postDate').value = new Date().toISOString().split('T')[0];
            }

            // 绑定发表按钮
            document.getElementById('publishBtn').addEventListener('click', savePost);

            // 位置输入实时更新标签
            document.getElementById('postPosition').addEventListener('input', (e) => {
                const label = document.getElementById('locationLabel');
                label.textContent = e.target.value || '所在位置';
            });
        });
    </script>
</body>
</html>
