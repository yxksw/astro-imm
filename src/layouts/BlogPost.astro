---
import type { CollectionEntry } from 'astro:content';
import BaseLayout from './BaseLayout.astro';
import PostCard from '../components/PostCard.astro';
import { SITE_TITLE } from '../consts';

type Props = CollectionEntry<'blog'>['data'] & { 
    slug: string;
    prev?: { slug: string; title: string } | null;
    next?: { slug: string; title: string } | null;
    rank?: number;
};

const { 
    title, 
    description, 
    pubDate, 
    updatedDate, 
    slug,
    isAdvertise,
    position,
    positionUrl,
    prev,
    next,
    rank
} = Astro.props;
---

<BaseLayout title={`${title} | ${SITE_TITLE}`} description={description}>
    <PostCard 
        title={title}
        description={description}
        pubDate={pubDate}
        updatedDate={updatedDate}
        slug={slug}
        isAdvertise={isAdvertise}
        position={position}
        positionUrl={positionUrl}
        isSingle={true}
        rank={rank}
        showEdit={true}
    />

    <!-- 文章内容 -->
    <div class="post-content text">
        <slot />
    </div>

    <!-- 灯箱覆盖层 -->
    <div class="lightbox-overlay" id="lightbox">
        <img src="" alt="" id="lightbox-img" />
    </div>

    <!-- 文章导航 -->
    <div class="post-nav-buttons">
        {next ? (
            <div class="nav-button next-button">
                <span class="button-label">⇐ 新的故事&nbsp;</span>
                <a href={`/blog/${next.slug}`} title={next.title}>{next.title}</a>
            </div>
        ) : (
            <div class="nav-button disabled">
                <span class="button-label">⇐ 暂无更多&nbsp;</span>
            </div>
        )}
        
        {prev ? (
            <div class="nav-button prev-button">
                <span class="button-label">&nbsp;旧的回忆 ⇒</span>
                <a href={`/blog/${prev.slug}`} title={prev.title}>{prev.title}</a>
            </div>
        ) : (
            <div class="nav-button disabled">
                <span class="button-label">&nbsp;没有更多 ⇒</span>
            </div>
        )}
    </div>

    <!-- Giscus 评论区域 -->
    <div class="giscus-container">
        <div class="giscus-wrapper">
            <script src="https://giscus.app/client.js"
                data-repo="yxksw/astro-imm"
                data-repo-id="R_kgDORchU3w"
                data-category="Announcements"
                data-category-id="DIC_kwDORchU384C3j9h"
                data-mapping="pathname"
                data-strict="1"
                data-reactions-enabled="1"
                data-emit-metadata="0"
                data-input-position="top"
                data-theme="preferred_color_scheme"
                data-lang="zh-CN"
                data-loading="lazy"
                crossorigin="anonymous"
                async>
            </script>
        </div>
    </div>
</BaseLayout>

<style>
    /* Giscus 评论区域样式 */
    .giscus-container {
        width: 100%;
        max-width: 640px;
        margin: 2rem auto 0;
        padding: 0 1rem;
    }

    .giscus-wrapper {
        background: var(--color-bg);
        border-radius: 8px;
        padding: 1rem;
    }

    /* 深色模式适配 */
    @media (prefers-color-scheme: dark) {
        .giscus-wrapper {
            background: var(--color-bg);
        }
    }
</style>

<script>
    // 灯箱功能
    document.addEventListener('DOMContentLoaded', function() {
        const lightbox = document.getElementById('lightbox') as HTMLElement | null;
        const lightboxImg = document.getElementById('lightbox-img') as HTMLImageElement | null;

        // 为文章中的图片添加灯箱功能
        const images = document.querySelectorAll('.post-content img, .text img');
        images.forEach(img => {
            const imgElement = img as HTMLImageElement;
            imgElement.classList.add('simple-lightbox');
            imgElement.style.cursor = 'pointer';

            imgElement.addEventListener('click', function() {
                if (lightbox && lightboxImg) {
                    lightboxImg.src = imgElement.src;
                    lightbox.style.display = 'flex';
                }
            });
        });

        // 点击灯箱关闭
        lightbox?.addEventListener('click', function() {
            lightbox.style.display = 'none';
        });
    });

    // Giscus 主题切换
    function updateGiscusTheme() {
        const iframe = document.querySelector('iframe.giscus-frame') as HTMLIFrameElement | null;
        if (iframe && iframe.contentWindow) {
            const isDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
            const theme = isDark ? 'dark' : 'light';
            iframe.contentWindow.postMessage({
                giscus: {
                    setConfig: {
                        theme: theme
                    }
                }
            }, 'https://giscus.app');
        }
    }

    // 监听系统主题变化
    window.matchMedia('(prefers-color-scheme: dark)').addEventListener('change', updateGiscusTheme);

    // 页面加载完成后更新一次主题
    document.addEventListener('DOMContentLoaded', function() {
        // 等待 Giscus iframe 加载完成
        setTimeout(updateGiscusTheme, 2000);
    });
</script>
