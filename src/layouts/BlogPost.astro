---
import type { CollectionEntry } from 'astro:content';
import BaseLayout from './BaseLayout.astro';
import PostCard from '../components/PostCard.astro';
import { SITE_TITLE } from '../consts';

type Props = CollectionEntry<'blog'>['data'] & { 
    slug: string;
    prev?: { slug: string; title: string } | null;
    next?: { slug: string; title: string } | null;
};

const { 
    title, 
    description, 
    pubDate, 
    updatedDate, 
    slug,
    isAdvertise,
    position,
    positionUrl,
    prev,
    next
} = Astro.props;

// 获取文章内容
const { Content } = await Astro.props.render?.() || { Content: null };
---

<BaseLayout title={`${title} | ${SITE_TITLE}`} description={description}>
    <PostCard 
        title={title}
        description={description}
        pubDate={pubDate}
        updatedDate={updatedDate}
        slug={slug}
        isAdvertise={isAdvertise}
        position={position}
        positionUrl={positionUrl}
        isSingle={true}
        content={Content ? '' : description || ''}
    />
    
    {Content && (
        <div class="post-content text">
            <Content />
        </div>
    )}

    <!-- 灯箱覆盖层 -->
    <div class="lightbox-overlay" id="lightbox">
        <img src="" alt="" id="lightbox-img" />
    </div>

    <!-- 文章导航 -->
    <div class="post-nav-buttons">
        {next ? (
            <div class="nav-button next-button">
                <span class="button-label">⇐ 新的故事&nbsp;</span>
                <a href={`/blog/${next.slug}`} title={next.title}>{next.title}</a>
            </div>
        ) : (
            <div class="nav-button disabled">
                <span class="button-label">⇐ 暂无更多&nbsp;</span>
            </div>
        )}
        
        {prev ? (
            <div class="nav-button prev-button">
                <span class="button-label">&nbsp;旧的回忆 ⇒</span>
                <a href={`/blog/${prev.slug}`} title={prev.title}>{prev.title}</a>
            </div>
        ) : (
            <div class="nav-button disabled">
                <span class="button-label">&nbsp;没有更多 ⇒</span>
            </div>
        )}
    </div>
</BaseLayout>

<script>
    // 灯箱功能
    document.addEventListener('DOMContentLoaded', function() {
        const lightbox = document.getElementById('lightbox');
        const lightboxImg = document.getElementById('lightbox-img') as HTMLImageElement;
        
        // 为文章中的图片添加灯箱功能
        const images = document.querySelectorAll('.post-content img, .text img');
        images.forEach(img => {
            img.classList.add('simple-lightbox');
            img.style.cursor = 'pointer';
            
            img.addEventListener('click', function() {
                if (lightbox && lightboxImg) {
                    lightboxImg.src = (img as HTMLImageElement).src;
                    lightbox.style.display = 'flex';
                }
            });
        });
        
        // 点击灯箱关闭
        lightbox?.addEventListener('click', function() {
            lightbox.style.display = 'none';
        });
    });
</script>
