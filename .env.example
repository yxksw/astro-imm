# ============================================
# GitHub App 配置 - 用于内容管理（推荐）
# ============================================

# GitHub App ID
# 在 GitHub App 设置页面获取
PUBLIC_GITHUB_APP_ID=your-github-app-id

# GitHub App Private Key
# 下载的私钥文件内容（.pem文件的全部内容）
# 注意：私钥需要保留换行符，可以使用 \n 转义
GITHUB_APP_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nMIIEpAIBAAKCAQEA...\n-----END RSA PRIVATE KEY-----"

# GitHub 仓库配置
PUBLIC_GITHUB_OWNER=your-github-username
PUBLIC_GITHUB_REPO=your-blog-repo
PUBLIC_GITHUB_BRANCH=main

# ============================================
# 备用：GitHub Personal Access Token
# 如果不使用 GitHub App，可以使用 Token 方式
# ============================================

# GitHub Personal Access Token（需要 repo 权限）
# 在 https://github.com/settings/tokens 创建
# GITHUB_TOKEN=ghp_your_personal_access_token

# ============================================
# 网站配置
# ============================================

PUBLIC_SITE_URL=https://your-blog.vercel.app
